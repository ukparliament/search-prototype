<% unless certified_categories.blank? %>
  <dt>
    Certified as
  </dt>
  <% certified_categories.each do |certified_category| %>
    <dd>
      <%= search_link(certified_category) %>
    </dd>
  <% end %>
  <% unless certified_date.blank? %>
    <dd>
      <%= format_date(certified_date) %>
    </dd>
  <% end %>
<% end %>