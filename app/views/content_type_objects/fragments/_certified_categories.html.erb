<% unless certified_categories.blank? %>
  <dt>
    Certified as
  </dt>
  <dd>
    <%= render 'content_type_objects/fragments/list', items: certified_categories, terminator: '', singular: false %>
  </dd>
  <% unless certified_date.blank? %>
    <dd>
      <%= format_date(certified_date) %>
    </dd>
  <% end %>
<% end %>