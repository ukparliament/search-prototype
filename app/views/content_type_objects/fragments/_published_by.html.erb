<% if object.is_published && object.is_published[:value] %>
  <% unless object.section.blank? && object.published_by.blank? %>
    <dt>
      Published by
    </dt>
    <% unless object.section.blank? %>
      <% object.sections.each do |section| %>
        <dd>
          <%= search_link(section) %>
        </dd>
      <% end %>
    <% end %>
    <% unless object.published_by.blank? %>
      <% unless object.sections && object.sections.pluck(:value).include?(object.published_by.dig(:value)) %>
        <dd>
          <%= search_link(object.published_by) %>
        </dd>
      <% end %>
    <% end %>
  <% end %>
<% end %>