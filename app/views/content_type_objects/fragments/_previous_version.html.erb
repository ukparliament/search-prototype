<% unless previous_version.blank? %>
  <dt>
    Previous version
  </dt>
  <dd>
    <%= object_show_link(previous_version.version_title, previous_version.object_uri) %>
  </dd>
  <% unless previous_version.date_of_order.blank? %>
    <dd>
      <%= format_date(previous_version.date_of_order) %>
    </dd>
  <% end %>
  <% unless previous_version.reference.blank? || previous_version.reference.pluck(:value) == ["."] %>
    <dd>
      <%= previous_version.reference.pluck(:value).join(' ') %>
    </dd>
  <% end %>
<% end %>