<% unless object.corrected_answer.blank? && object.correcting_item_link.blank? %>
  <dt>Corrected answer</dt>
  <% unless object.corrected_answer.blank? %>
    <dd>
      <%= raw(object.corrected_answer[:value]) %>
    </dd>
  <% end %>
  <% unless object.correcting_item_link.blank? %>
    <dd>
      <%= raw(@associated_object_data[object.correcting_item_link]&.correction_text[:value]) %>
    </dd>
  <% end %>
<% end %>