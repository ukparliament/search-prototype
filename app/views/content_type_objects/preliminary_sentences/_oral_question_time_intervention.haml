%p.font-size-epsilon.reading-width
  %span>= search_link(object.object_name, singular: true)
  - unless object.date.blank?
    %span= " made on "
    %span>= format_date(object.date)
  %span= " in the "
  %span>= render 'content_type_objects/fragments/list', items: object.legislature, terminator: '', singular: false
  - unless object.member.blank?
    %span= " by "
    %span>= search_link(object.member)
    - unless object.member_party.blank?
      %span= " ("
      %span>= search_link(object.member_party)
      %span>= ")"
  %span>="."