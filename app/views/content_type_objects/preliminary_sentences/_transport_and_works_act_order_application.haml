%p.font-size-epsilon.reading-width
  %span>= search_link(object.object_name, singular: true)
  %span= " deposited in Parliament "
  - unless object.depositing_agent.blank?
    %span= " by "
    %span>= search_link(object.depositing_agent)
    %span= " as the agent, "
  - unless object.depositing_applicant.blank?
    %span= " for "
    %span>= search_link(object.depositing_applicant)
    %span= " as the applicant, "
  - unless object.date_originated.blank?
    %span= " on "
    %span>= format_date(object.date_originated)
  %span= "."