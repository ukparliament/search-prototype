%p.font-size-epsilon.reading-width
  %span>= search_link(object.object_name, singular: true)
  %span= " became law on "
  %span>= format_date(object.date)
  - unless bill.blank?
    %span= " when the "
    %span>= object_show_link(bill.object_title, bill.object_uri)
    %span>= " received Royal Assent"
  %span= "."