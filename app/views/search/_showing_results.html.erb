<section class="search-summary wrap-anywhere">
  <p class="font-size-epsilon">
    <strong><%= @search_data.start %>-<%= [@search_data.end, @search_data.number_of_results].min %></strong>
    of
    <strong><%= number_to_delimited(@search_data.number_of_results, separator: ",") %></strong>
    results for
    <strong><%= @search_data.query %></strong>
  </p>
</section>
